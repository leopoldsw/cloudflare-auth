{
  "name": "create-cloudflare-auth",
  "version": "0.0.0",
  "private": true,
  "description": "Create a Cloudflare Auth starter app.",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "create-cloudflare-auth": "./dist/bin.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm,cjs --clean --sourcemap && tsc -p tsconfig.json --emitDeclarationOnly",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@cf-auth/cli": "workspace:*"
  }
}
