{
  "name": "@cf-auth/client",
  "version": "0.0.0",
  "description": "Browser client SDK for Cloudflare Auth.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --clean --sourcemap --platform browser && tsc -p tsconfig.json --emitDeclarationOnly",
    "test": "vitest run --passWithNoTests"
  }
}
